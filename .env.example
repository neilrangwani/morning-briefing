# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Resend email delivery (optional) — get a key at resend.com
# If not set, the briefing only prints to the terminal/Actions log
RESEND_API_KEY=re_...
TO_EMAIL=you@gmail.com
